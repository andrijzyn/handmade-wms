            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/products/{{temp_product_id}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{temp_product_id}}"
          ]
        }
      },
      "response": []
    },
